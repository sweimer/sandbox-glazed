<?php

/**
 * Implements hook_theme().
 */
function hudx_react_poc_11_theme($existing, $type, $theme, $path) {
  return [
    'hudx_react_poc_11_block' => [
      'variables' => [],
      'template' => 'hudx-react-poc-11-block',
      'path' => \Drupal::service('extension.list.module')->getPath('hudx_react_poc_11') . '/templates',
    ],
  ];
}
