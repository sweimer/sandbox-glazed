 * Clear all caches to apply bug fixes and improvements.
 */
function dxpr_builder_update_9010(): void {
  // Rebuild container and clear all caches using modern service-based approach.
  \Drupal::service('kernel')->invalidateContainer();
  \Drupal::service('cache_tags.invalidator')->invalidateTags(['rendered']);
}

/**
 * Enable AI Assistant and AI Tone of Voice buttons for all user profiles.
 */
function dxpr_builder_update_9011(): void {
  $entity_manager = \Drupal::entityTypeManager()->getStorage('dxpr_builder_profile');
  $profiles = $entity_manager->loadMultiple();

  /** @var \Drupal\dxpr_builder\Entity\DxprBuilderProfile $profile */
  foreach ($profiles as $profile) {
    $changed = FALSE;

    // Get current inline buttons.
    $inline_buttons = $profile->get('inline_buttons') ?: [];

    // Add AI buttons to inline mode if not already present.
    if (!in_array('aiAgentButton', $inline_buttons)) {
      $inline_buttons[] = 'aiAgentButton';
      $changed = TRUE;
    }
    if (!in_array('aiAgentToneButton', $inline_buttons)) {
      $inline_buttons[] = 'aiAgentToneButton';
      $changed = TRUE;
    }

    // Get current modal buttons.
    $modal_buttons = $profile->get('modal_buttons') ?: [];

    // Add AI buttons to modal mode if not already present.
    if (!in_array('aiAgentButton', $modal_buttons)) {
      $modal_buttons[] = 'aiAgentButton';
      $changed = TRUE;
    }
    if (!in_array('aiAgentToneButton', $modal_buttons)) {
      $modal_buttons[] = 'aiAgentToneButton';
      $changed = TRUE;
    }

    // Save the profile if changes were made.
    if ($changed) {
      $profile->set('inline_buttons', $inline_buttons);
      $profile->set('modal_buttons', $modal_buttons);
      $profile->save();
      \Drupal::logger('dxpr_builder')->info(
        'Enabled AI buttons for profile: @profile',
        ['@profile' => $profile->label()]
      );
    }
  }
}

/**
 * Restore ai_page_enabled setting with default value TRUE.
 */
function dxpr_builder_update_9012(): void {
  $config = \Drupal::configFactory()->getEditable('dxpr_builder.settings');

  // Set ai_page_enabled to TRUE by default (unless explicitly set otherwise).
  if ($config->get('ai_page_enabled') === NULL) {
    $config->set('ai_page_enabled', TRUE);
    $config->save();
    \Drupal::logger('dxpr_builder')->info('Restored ai_page_enabled setting with default value TRUE.');
  }
}

/**
 * Set AI output security defaults (CVE-2025-32711 / EchoLeak mitigation).
 *
 * Ensures ai_output_allowed_domains is set with sensible defaults including
 * promptahuman.com for placeholder images.
 */
function dxpr_builder_update_9013(): void {
  $config = \Drupal::configFactory()->getEditable('dxpr_builder.settings');
  $placeholder_domain = 'promptahuman.com';

  $domains = $config->get('ai_output_allowed_domains');

  // If not set, initialize with defaults.
  if ($domains === NULL) {
    $default_domains = implode("\n", [
      'unsplash.com',
      'images.unsplash.com',
      'pexels.com',
      'images.pexels.com',
      'pixabay.com',
      $placeholder_domain,
    ]);
    $config->set('ai_output_allowed_domains', $default_domains)->save();
    return;
  }

  // If wildcard (allow all), nothing to do.
  if ($domains === '*') {
    return;
  }

  // Ensure promptahuman.com is in the list.
  $domains_array = array_filter(array_map('trim', explode("\n", $domains)));
  if (!in_array($placeholder_domain, $domains_array, TRUE)) {
    $domains_array[] = $placeholder_domain;
    $config->set('ai_output_allowed_domains', implode("\n", $domains_array))->save();
  }
}

/**
 * Add ai_image_enabled setting with default value TRUE.
 */
function dxpr_builder_update_9015(): void {
  $config = \Drupal::configFactory()->getEditable('dxpr_builder.settings');
  if ($config->get('ai_image_enabled') === NULL) {
    $config->set('ai_image_enabled', TRUE)->save();
  }
  \Drupal::logger('dxpr_builder')->info('Added ai_image_enabled setting with default value TRUE.');
}
