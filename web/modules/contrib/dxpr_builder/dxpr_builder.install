  $config_factory = \Drupal::configFactory();
  $config = $config_factory->getEditable('dxpr_builder.settings');
  $config->set('hide_reminders', TRUE);
  $config->save(TRUE);
}

/**
 * Migrate CKE4 toolbar button config to CKE5.
 */
function dxpr_builder_update_8036(): void {
  $plugins = [
    'Strike' => 'strikethrough',
    'JustifyLeft' => 'alignment:left',
    'JustifyRight' => 'alignment:right',
    'JustifyCenter' => 'alignment:center',
    'JustifyBlock' => 'alignment:justify',
    'Image' => 'insertImage',
    'Table' => 'insertTable',
    'HorizontalRule' => 'horizontalLine',
    'SpecialChar' => 'specialCharacters',
    'TextColor' => 'fontColor',
    'BGColor' => 'fontBackgroundColor',
    'Blockquote' => 'blockQuote',
    'Source' => 'sourceEditing',
    'Format' => 'heading',
    'Styles' => 'style',
    'SelectAll' => 'selectAll',
    'Replace' => 'findAndReplace',
    'Iframe' => 'mediaEmbed',
    // Remove plugins.
    'Copy' => '',
    'Font' => '',
    'Templates' => '',
    'SpellChecker' => '',
    'Scayt' => '',
    'Cut' => '',
    'Paste' => '',
    'PasteText' => '',
    'PasteFromWord' => '',
    'Unlink' => '',
    'Find' => '',
    'CreateDiv' => '',
    'Maximize' => '',
    'About' => '',
    'NewPage' => '',
    'Preview' => '',
    'Smiley' => '',
    'BidiRtl' => '',
    'BidiLtr' => '',
    'Anchor' => '',
    'PageBreak' => '',
    'CopyFormatting' => '',
  ];

  $entity_manager = \Drupal::entityTypeManager()->getStorage('dxpr_builder_profile');
  $profiles = $entity_manager->loadMultiple();

  /** @var \Drupal\dxpr_builder\Entity\DxprBuilderProfile $profile */
  foreach ($profiles as $profile) {
    $inline_plugins = $profile->get('inline_buttons');
    $modal_plugins = $profile->get('modal_buttons');

    // Inline settings.
    foreach ($inline_plugins as &$inline_plugin) {
      $inline_plugin = lcfirst($plugins[$inline_plugin] ?? $inline_plugin);
    }

    // Modal settings.
    foreach ($modal_plugins as &$modal_plugin) {
      $modal_plugin = lcfirst($plugins[$modal_plugin] ?? $modal_plugin);
    }

    // Clean up empty values and reindex array.
    $inline_plugins = array_filter(array_values($inline_plugins));
    $modal_plugins = array_filter(array_values($modal_plugins));

    $profile->set('inline_buttons', $inline_plugins);
    $profile->set('modal_buttons', $modal_plugins);
    $profile->save();
  }
}

/**
 * Add default image style for fast loading images.
 */
function dxpr_builder_update_8037(): void {
  $config_name = 'image.style.optimize';

  // Load data from file.
  $config_path = \Drupal::service('extension.list.module')->getPath('dxpr_builder') . '/config/optional';
  $source = new FileStorage($config_path);
  $data = $source->read($config_name);

  // Update data in DB.
  $config_factory = \Drupal::configFactory();
  $config = $config_factory->getEditable($config_name);
  $config->setData($data)->save(TRUE);
}

/**
 * Clear all caches to register new Key module integration services.
 */
function dxpr_builder_update_8038(): void {
  // The Key module integration adds new services that need to be discovered,
  // requiring a cache clear to rebuild the service container.
  \Drupal::service('kernel')->invalidateContainer();
  \Drupal::service('cache_tags.invalidator')->invalidateTags(['rendered']);
}

/**
 * Fix image styles with incomplete image_scale_and_crop configurations.
 */
function _dxpr_builder_fix_image_scale_and_crop_styles(): void {
  // Load all image styles.
  $image_styles = \Drupal::configFactory()->listAll('image.style.');
  $config_factory = \Drupal::configFactory();

  foreach ($image_styles as $style_config_name) {
    $style = $config_factory->getEditable($style_config_name);
    $effects = $style->get('effects') ?? [];
    $needs_save = FALSE;

    foreach ($effects as $effect_uuid => $effect) {
      // Check for image_scale_and_crop effects.
      if ($effect['id'] === 'image_scale_and_crop') {
        $width = $effect['data']['width'] ?? NULL;
        $height = $effect['data']['height'] ?? NULL;

        // If only width is set, set height equal to width.
        if ($width && !$height) {
          $style->set("effects.$effect_uuid.data.height", $width);
          $needs_save = TRUE;
        }
        // If only height is set, set width equal to height.
        elseif (!$width && $height) {
          $style->set("effects.$effect_uuid.data.width", $height);
          $needs_save = TRUE;
        }
      }
    }

    if ($needs_save) {
      $style->save(TRUE);
      \Drupal::logger('dxpr_builder')->notice(
        'Updated incomplete image_scale_and_crop configuration in image style: @style',
        ['@style' => $style->get('name')]
      );
    }
  }
}

/**
 * Fix image styles with incomplete image_scale_and_crop configurations.
 */
function dxpr_builder_update_8039(): void {
  _dxpr_builder_fix_image_scale_and_crop_styles();
}

/**
 * Add tone of voice and commands vocabularies for AI integration.
 */
function dxpr_builder_update_9007(): void {
  _dxpr_builder_create_command_vocabulary();
  _dxpr_builder_create_tone_vocabulary();
}

/**
 * Migrate ai_page_enabled setting into ai_enabled setting.
 */
function dxpr_builder_update_9008(): void {
  $config = \Drupal::configFactory()->getEditable('dxpr_builder.settings');

  // Set ai_enabled to TRUE by default.
  $config->set('ai_enabled', TRUE);

  // Remove the deprecated ai_page_enabled setting.
  $config->clear('ai_page_enabled');

  // Save the configuration.
  $config->save();

  \Drupal::logger('dxpr_builder')->info('Migrated ai_page_enabled setting to ai_enabled.');
}

/**
 * Helper function to create the command vocabulary and default terms.
 *
 * @return string
 *   The vocabulary machine name.
 */
function _dxpr_builder_create_command_vocabulary(): string {
  $command_vocabulary_name = 'ai_agent_commands';
  $vocabulary_exists = \Drupal::entityTypeManager()
    ->getStorage('taxonomy_vocabulary')
    ->load($command_vocabulary_name);

  if (!$vocabulary_exists) {
    $vocabulary = Vocabulary::create([
      'vid' => $command_vocabulary_name,
      'name' => 'AI Edit Commands',
      'description' => 'Commands for AI editing tools',
    ]);
    $vocabulary->save();

    $default_commands = [
      'Edit or review' => [
        'Polish' => 'Fix spelling mistakes, use proper grammar and apply good writing practices.
Do not lose the original meaning.
You must keep the text formatting.',
        'Improve Tone of Voice' => 'Rewrite the content to match the TONE while preserving the key message and meaning.
Ensure the writing style is consistent.
You must keep the text formatting.',
        'Make Shorter' => 'Remove any repetitive, redundant, or non-essential writing in this
content without changing the meaning or losing any key information.',
        'Make Longer' => 'Improve this content by using descriptive language and inserting
more information and more detailed explanations.
You must keep the text formatting.',
        'Simplify Language' => 'Simplify the writing style of this content and reduce the complexity,
so that the content is easy to understand.
You must keep the text formatting',
      ],
      'Generate from selection' => [
        'Summarize' => 'Summarize this content into one paragraph of text. Include only the key ideas and conclusions.
Keep it short. Do not keep original text formatting',
        'Continue' => 'Start with the provided content and write at the end of it continuing this topic.
Keep the added part short.
You must keep the text formatting',
      ],
    ];

    foreach ($default_commands as $category => $commands) {
      $category_term = Term::create([
        'vid' => $command_vocabulary_name,
        'name' => $category,
      ]);
      $category_term->save();

      foreach ($commands as $command_name => $command_instruction) {
        // Make sure the description field is properly formatted.
        $command_term = Term::create([
          'vid' => $command_vocabulary_name,
          'name' => $command_name,
          'description' => [
            'value' => $command_instruction,
            'format' => 'plain_text',
          ],
          'parent' => [$category_term->id()],
        ]);
        $command_term->save();
      }
    }
  }

  // Check if we need to set the configuration.
  $config = \Drupal::configFactory()->getEditable('dxpr_builder.settings');
  $existing_vocab = $config->get('commands_vocabulary');

  // Only set the vocabulary in configuration if it's not already set.
  if (empty($existing_vocab)) {
    $config->set('commands_vocabulary', $command_vocabulary_name)
      ->set('enable_taxonomy_commands', TRUE)
      ->save();
  }

  return $command_vocabulary_name;
}

/**
 * Helper function to create the tone of voice vocabulary and default terms.
 *
 * @return string
 *   The vocabulary machine name.
 */
function _dxpr_builder_create_tone_vocabulary(): string {
  $tone_vocabulary_name = 'ai_tone_of_voice';
  $vocabulary_exists = \Drupal::entityTypeManager()
    ->getStorage('taxonomy_vocabulary')
    ->load($tone_vocabulary_name);

  if (!$vocabulary_exists) {
    $vocabulary = Vocabulary::create([
      'vid' => $tone_vocabulary_name,
      'name' => 'AI Tone of Voice',
      'description' => 'Tones of voice for AI content generation',
    ]);
    $vocabulary->save();

    $default_tones = [
      'Professional' => 'Use clear, concise language with a business-appropriate tone suitable for formal contexts.',
      'Educational' => 'Explain concepts clearly with an informative approach that helps readers understand complex topics.',
      'Persuasive' => 'Use compelling language to convince readers and support arguments with strong reasoning.',
      'Approachable' => 'Write in a friendly and accessible manner, like talking to a friend, but in a sincere and professional context.',
      'Formal' => 'Employ precise, structured language appropriate for official documentation and communications.',
      'Inspirational' => 'Use motivational language that encourages action and creates a sense of possibility.',
    ];

    foreach ($default_tones as $tone_name => $tone_description) {
      // Make sure the description field is properly formatted.
      $tone_term = Term::create([
        'vid' => $tone_vocabulary_name,
        'name' => $tone_name,
        'description' => [
          'value' => $tone_description,
          'format' => 'plain_text',
        ],
      ]);
      $tone_term->save();
    }
  }

  // Check if we need to set the configuration.
  $config = \Drupal::configFactory()->getEditable('dxpr_builder.settings');
  $existing_vocab = $config->get('tone_of_voice_vocabulary');

  // Only set the vocabulary in configuration if it's not already set.
  if (empty($existing_vocab)) {
    $config->set('tone_of_voice_vocabulary', $tone_vocabulary_name)
      ->set('enable_taxonomy_tones', TRUE)
      ->save();
  }

  return $tone_vocabulary_name;
}

/**
 * Migrate drm_last_contact from config to state.
 */
function dxpr_builder_update_9009(): void {
  $config = \Drupal::configFactory()->getEditable('dxpr_builder.settings');
  $drm_last_contact = $config->get('drm_last_contact');

  // Migrate to state if value exists.
  if ($drm_last_contact !== NULL) {
    \Drupal::state()->set('dxpr_builder.drm_last_contact', $drm_last_contact);
    // Remove from config.
    $config->clear('drm_last_contact')->save();
  }
}

