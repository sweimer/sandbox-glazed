{
  "name": "@drupal-canvas/vite-compat",
  "version": "0.0.0",
  "description": "Shared Vite compatibility helpers for Canvas runtimes",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./runtime": {
      "import": "./src/runtime.ts",
      "types": "./src/runtime.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "type-check": "tsc --noEmit --pretty"
  },
  "dependencies": {
    "js-yaml": "^4.1.1",
    "vite-plugin-svgr": "^4.5.0"
  },
  "peerDependencies": {
    "vite": "^6 || ^7"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
