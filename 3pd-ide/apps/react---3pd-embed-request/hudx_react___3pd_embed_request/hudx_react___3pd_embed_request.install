  $schema['hudx_react___3pd_embed_request_submissions'] = [
    'description' => 'Submissions table for the 3PD IDE - React   3pd Embed Request React app.',
    'fields' => [
        'id' => [
          'type' => 'serial',
          'unsigned' => TRUE,
          'not null' => TRUE,
        ],
        'submitter_name' => [
          'type' => 'text',
          'size' => 'big',
          'not null' => FALSE,
        ],
        'submitter_email' => [
          'type' => 'text',
          'size' => 'big',
          'not null' => FALSE,
        ],
        'submitter_dept' => [
          'type' => 'text',
          'size' => 'big',
          'not null' => FALSE,
        ],
        'type' => [
          'type' => 'text',
          'size' => 'big',
          'not null' => FALSE,
        ],
        'title' => [
          'type' => 'text',
          'size' => 'big',
          'not null' => FALSE,
        ],
        'description' => [
          'type' => 'text',
          'size' => 'big',
          'not null' => FALSE,
        ],
        'justification' => [
          'type' => 'text',
          'size' => 'big',
          'not null' => FALSE,
        ],
        'url' => [
          'type' => 'text',
          'size' => 'big',
          'not null' => FALSE,
        ],
        'code_snippet' => [
          'type' => 'text',
          'size' => 'big',
          'not null' => FALSE,
        ],
        'requested_placement' => [
          'type' => 'text',
          'size' => 'big',
          'not null' => FALSE,
        ],
        'data_sensitivity' => [
          'type' => 'text',
          'size' => 'big',
          'not null' => FALSE,
        ],
        'collects_user_data' => [
          'type' => 'int',
          'not null' => FALSE,
        ],
        'requires_auth' => [
          'type' => 'int',
          'not null' => FALSE,
        ],
        'go_live_date' => [
          'type' => 'text',
          'size' => 'big',
          'not null' => FALSE,
        ],
        'status' => [
          'type' => 'text',
          'size' => 'big',
          'not null' => FALSE,
        ],
        'admin_notes' => [
          'type' => 'text',
          'size' => 'big',
          'not null' => FALSE,
        ],
        'created_at' => [
          'type' => 'text',
          'size' => 'big',
          'not null' => FALSE,
        ],
    ],
    'primary key' => ['id'],
  ];
  return $schema;
