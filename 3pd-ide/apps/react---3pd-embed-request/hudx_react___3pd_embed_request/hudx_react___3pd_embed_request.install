/**
 * Implements hook_install().
 */
function hudx_react___3pd_embed_request_install() {
  _hudx_react___3pd_embed_request_import_seed();
}

/**
 * Import seed data from data/seed.json into the Drupal submissions table.
 * Called on install and by post_deploy.php on every Pantheon push.
 */
function _hudx_react___3pd_embed_request_import_seed() {
  $seed_path = \Drupal::service('extension.list.module')->getPath('hudx_react___3pd_embed_request') . '/data/seed.json';
  if (!file_exists($seed_path)) {
    return;
  }

  $seed = json_decode(file_get_contents($seed_path), TRUE);
  if (empty($seed['rows'])) {
    return;
  }

  $db = \Drupal::database();
  $db->truncate('hudx_react___3pd_embed_request_submissions')->execute();

  foreach ($seed['rows'] as $row) {
    unset($row['id']);
    $db->insert('hudx_react___3pd_embed_request_submissions')->fields($row)->execute();
  }
}
