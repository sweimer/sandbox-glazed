---
import Layout from '../layouts/Layout.astro';
---

<Layout title="3PD Module Checklist">
  <main style="padding: 2rem; max-width: 960px;">
    <h1 style="margin-bottom: 0.25rem;">3PD Module Checklist</h1>
    <p style="color: #666; margin-top: 0; margin-bottom: 1.5rem;">
      Check each module as tested. Changes save automatically.
    </p>

    <p id="load-status" style="color: #999;">Loading…</p>
    <p id="empty-msg"   style="color: #999; display: none;">No 3PD modules found.</p>

    <!-- ================================================================
         FILTER BAR — hidden until data loads
         ================================================================ -->
    <div id="filter-bar" style="display: none; margin-bottom: 1rem; gap: 0.6rem; flex-wrap: wrap; align-items: center;">
      <select id="filter-checked" style="padding: 0.35rem 0.6rem; border: 1px solid #ccc; border-radius: 4px; font-size: 0.875em; cursor: pointer;">
        <option value="">All ✓</option>
        <option value="1">Checked</option>
        <option value="0">Unchecked</option>
      </select>

      <select id="filter-tech" style="padding: 0.35rem 0.6rem; border: 1px solid #ccc; border-radius: 4px; font-size: 0.875em; cursor: pointer;">
        <option value="">All Tech</option>
      </select>

      <input id="filter-module" type="text" placeholder="Filter module…"
        style="padding: 0.35rem 0.6rem; border: 1px solid #ccc; border-radius: 4px; font-size: 0.875em; min-width: 160px;">

      <select id="filter-status" style="padding: 0.35rem 0.6rem; border: 1px solid #ccc; border-radius: 4px; font-size: 0.875em; cursor: pointer;">
        <option value="">All Workflow</option>
        <option value="Not Tested">Not Tested</option>
        <option value="Tested">Tested</option>
        <option value="Returned">Returned</option>
        <option value="Approved">Approved</option>
        <option value="Ready for Deploy">Ready for Deploy</option>
        <option value="Deployed">Deployed</option>
      </select>

      <button id="filter-clear" style="padding: 0.35rem 0.7rem; border: 1px solid #ccc; border-radius: 4px;
        font-size: 0.875em; background: #fff; cursor: pointer; color: #666;">
        Clear
      </button>

      <span id="filter-count" style="font-size: 0.8em; color: #999; margin-left: 0.25rem;"></span>
    </div>

    <!-- ================================================================
         TABLE
         ================================================================ -->
    <table id="checklist-table" style="width: 100%; border-collapse: collapse; display: none;">
      <thead>
        <tr style="background: #f5f5f5;" id="header-row">
          <th id="th-checked"
              style="padding: 0.6rem 0.75rem; text-align: center; border-bottom: 2px solid #ddd;
                     width: 48px; cursor: pointer; user-select: none; white-space: nowrap;">
            ✓
          </th>
          <th id="th-tech"
              style="padding: 0.6rem 0.75rem; text-align: left; border-bottom: 2px solid #ddd;
                     width: 120px; cursor: pointer; user-select: none; white-space: nowrap;">
            Tech
          </th>
          <th id="th-module"
              style="padding: 0.6rem 0.75rem; text-align: left; border-bottom: 2px solid #ddd;
                     cursor: pointer; user-select: none; white-space: nowrap;">
            Module
          </th>
          <th style="padding: 0.6rem 0.75rem; text-align: left; border-bottom: 2px solid #ddd; width: 220px;">
            Tester Name
          </th>
          <th id="th-status"
              style="padding: 0.6rem 0.75rem; text-align: left; border-bottom: 2px solid #ddd;
                     width: 200px; cursor: pointer; user-select: none; white-space: nowrap;">
            Workflow
          </th>
        </tr>
      </thead>
      <tbody id="checklist-body"></tbody>
    </table>
  </main>
</Layout>

<script>
  const DRUPAL_BASE = import.meta.env.PUBLIC_DRUPAL_BASE_URL || '';
  const API_BASE    = import.meta.env.PUBLIC_API_BASE_URL    || '';
  const APP_SLUG    = import.meta.env.PUBLIC_APP_SLUG        || '';

  let modules   = [];
  let checklist = {}; // keyed by module_name

  // Sort state
  let sortCol = 'tech';  // 'checked' | 'tech' | 'module' | 'status'
  let sortDir = 'asc';   // 'asc' | 'desc'

  // Filter state
  const filters = { checked: '', tech: '', module: '', status: '' };

  // -----------------------------------------------------------------------
  // Bootstrap
  // -----------------------------------------------------------------------
  async function init() {
    try {
      const [modRes, checkRes] = await Promise.all([
        fetch(`${API_BASE}/api/${APP_SLUG}/modules`),
        fetch(`${API_BASE}/api/${APP_SLUG}/checklist`),
      ]);
      if (!modRes.ok)   throw new Error(`Modules fetch failed: HTTP ${modRes.status}`);
      if (!checkRes.ok) throw new Error(`Checklist fetch failed: HTTP ${checkRes.status}`);

      modules = await modRes.json();
      const rows = await checkRes.json();
      checklist = Object.fromEntries(rows.map(r => [r.module_name, r]));

      document.getElementById('load-status').style.display = 'none';

      if (modules.length === 0) {
        document.getElementById('empty-msg').style.display = 'block';
        return;
      }

      buildTechFilter();
      attachFilterListeners();
      attachSortListeners();
      renderTable();

      document.getElementById('checklist-table').style.display = 'table';
      document.getElementById('filter-bar').style.display = 'flex';
    } catch (err) {
      const s = document.getElementById('load-status');
      s.textContent = `Error loading checklist: ${err.message}`;
      s.style.color = '#c00';
    }
  }

  // -----------------------------------------------------------------------
  // Build tech filter options from actual data
  // -----------------------------------------------------------------------
  function buildTechFilter() {
    const sel   = document.getElementById('filter-tech');
    const types = [...new Set(modules.map(m => m.tech_type))].sort();
    types.forEach(t => {
      const opt = document.createElement('option');
      opt.value = t;
      opt.textContent = t;
      sel.appendChild(opt);
    });
  }

  // -----------------------------------------------------------------------
  // Filter + sort pipeline
  // -----------------------------------------------------------------------
  function getFilteredSorted() {
    let result = [...modules];

    // --- Filters ---
    if (filters.checked !== '') {
      result = result.filter(m => {
        const c = (checklist[m.module_name] || {}).checked;
        return String(c == 1 ? '1' : '0') === filters.checked;
      });
    }
    if (filters.tech) {
      result = result.filter(m => m.tech_type === filters.tech);
    }
    if (filters.module) {
      const q = filters.module.toLowerCase();
      result = result.filter(m => m.display_name.toLowerCase().includes(q));
    }
    if (filters.status) {
      result = result.filter(m => {
        const s = checklist[m.module_name] || {};
        return (s.workflow_status || 'Not Tested') === filters.status;
      });
    }

    // --- Sort ---
    if (sortCol) {
      result.sort((a, b) => {
        let av, bv;
        const sa = checklist[a.module_name] || {};
        const sb = checklist[b.module_name] || {};

        if      (sortCol === 'checked') { av = sa.checked == 1 ? 1 : 0;  bv = sb.checked == 1 ? 1 : 0; }
        else if (sortCol === 'tech')    { av = a.tech_type;               bv = b.tech_type; }
        else if (sortCol === 'module')  { av = a.display_name;            bv = b.display_name; }
        else if (sortCol === 'status')  {
          const ORDER = ['Not Tested', 'Tested', 'Returned', 'Approved', 'Ready for Deploy', 'Deployed'];
          av = ORDER.indexOf(sa.workflow_status || 'Not Tested');
          bv = ORDER.indexOf(sb.workflow_status || 'Not Tested');
        }

        if (av < bv) return sortDir === 'asc' ? -1 : 1;
        if (av > bv) return sortDir === 'asc' ?  1 : -1;
        return 0;
      });
    }

    return result;
  }

  // -----------------------------------------------------------------------
  // Render tbody from filtered+sorted list
  // -----------------------------------------------------------------------
  function renderTable() {
    const visible = getFilteredSorted();
    const tbody   = document.getElementById('checklist-body');
    tbody.innerHTML = visible.map(mod => rowHtml(mod)).join('');
    attachRowListeners(tbody);
    updateFilterCount(visible.length);
    updateSortIndicators();
  }

  function updateFilterCount(visible) {
    const el = document.getElementById('filter-count');
    const isFiltered = filters.checked || filters.tech || filters.module || filters.status;
    el.textContent = isFiltered ? `${visible} of ${modules.length} shown` : '';
  }

  function updateSortIndicators() {
    const cols = { checked: 'th-checked', tech: 'th-tech', module: 'th-module', status: 'th-status' };
    const labels = { checked: '✓', tech: 'Tech', module: 'Module', status: 'Status' };
    for (const [col, id] of Object.entries(cols)) {
      const th = document.getElementById(id);
      if (!th) continue;
      const indicator = (sortCol === col) ? (sortDir === 'asc' ? ' ▲' : ' ▼') : ' ↕';
      th.textContent = labels[col] + indicator;
    }
  }

  // -----------------------------------------------------------------------
  // Row HTML
  // -----------------------------------------------------------------------
  const WF_OPTIONS = ['Not Tested', 'Tested', 'Returned', 'Approved', 'Ready for Deploy', 'Deployed'];

  function rowHtml(mod) {
    const state     = checklist[mod.module_name] || { checked: 0, tester_name: '', workflow_status: 'Not Tested' };
    const isChecked = state.checked == 1;
    const rowBg     = isChecked ? '#f0fff0' : '';
    const wfStatus  = state.workflow_status || 'Not Tested';

    const options = WF_OPTIONS.map(opt =>
      `<option value="${opt}"${opt === wfStatus ? ' selected' : ''}>${opt}</option>`
    ).join('');

    return `<tr data-module="${mod.module_name}" style="background:${rowBg}">
      <td style="padding: 0.5rem 0.75rem; border-bottom: 1px solid #eee; text-align: center;">
        <input type="checkbox" ${isChecked ? 'checked' : ''}
          style="width: 16px; height: 16px; cursor: pointer; accent-color: #060;">
      </td>
      <td style="padding: 0.5rem 0.75rem; border-bottom: 1px solid #eee; color: #555; font-size: 0.85em;">
        ${mod.tech_type}
      </td>
      <td style="padding: 0.5rem 0.75rem; border-bottom: 1px solid #eee; font-family: monospace; font-size: 0.9em;">
        <a href="${DRUPAL_BASE}/hudx-test/${mod.module_name}" target="_blank" rel="noopener"
           style="color: inherit; text-decoration: underline dotted; text-underline-offset: 3px;">
          ${mod.display_name}
        </a>
      </td>
      <td style="padding: 0.5rem 0.75rem; border-bottom: 1px solid #eee;">
        <input type="text" value="${escHtml(state.tester_name || '')}" placeholder="Enter tester name"
          style="width: 100%; padding: 0.3rem 0.5rem; border: 1px solid #ddd; border-radius: 3px;
                 font-size: 0.9em; box-sizing: border-box;">
      </td>
      <td style="padding: 0.5rem 0.75rem; border-bottom: 1px solid #eee;">
        <select style="width: 100%; padding: 0.3rem 0.4rem; border: 1px solid #ddd; border-radius: 3px;
                       font-size: 0.85em; cursor: pointer; box-sizing: border-box;">
          ${options}
        </select>
      </td>
    </tr>`;
  }

  function escHtml(str) {
    return str.replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;');
  }

  // -----------------------------------------------------------------------
  // Sort listeners — column headers
  // -----------------------------------------------------------------------
  function attachSortListeners() {
    const sortMap = { 'th-checked': 'checked', 'th-tech': 'tech', 'th-module': 'module', 'th-status': 'status' };
    for (const [id, col] of Object.entries(sortMap)) {
      document.getElementById(id)?.addEventListener('click', () => {
        if (sortCol === col) {
          sortDir = sortDir === 'asc' ? 'desc' : 'asc';
        } else {
          sortCol = col;
          sortDir = 'asc';
        }
        renderTable();
      });
    }
  }

  // -----------------------------------------------------------------------
  // Filter listeners
  // -----------------------------------------------------------------------
  function attachFilterListeners() {
    document.getElementById('filter-checked').addEventListener('change', (e) => {
      filters.checked = e.target.value;
      renderTable();
    });
    document.getElementById('filter-tech').addEventListener('change', (e) => {
      filters.tech = e.target.value;
      renderTable();
    });
    document.getElementById('filter-module').addEventListener('input', (e) => {
      filters.module = e.target.value.trim();
      renderTable();
    });
    document.getElementById('filter-status').addEventListener('change', (e) => {
      filters.status = e.target.value;
      renderTable();
    });
    document.getElementById('filter-clear').addEventListener('click', () => {
      filters.checked = filters.tech = filters.module = filters.status = '';
      document.getElementById('filter-checked').value = '';
      document.getElementById('filter-tech').value    = '';
      document.getElementById('filter-module').value  = '';
      document.getElementById('filter-status').value  = '';
      renderTable();
    });
  }

  // -----------------------------------------------------------------------
  // Row event delegation — checkbox changes + tester name blur
  // -----------------------------------------------------------------------
  function getRowFields(row) {
    const checkbox  = row.querySelector('input[type="checkbox"]');
    const nameInput = row.querySelector('input[type="text"]');
    const wfSelect  = row.querySelector('select');
    return {
      checked:         checkbox.checked ? 1 : 0,
      tester_name:     nameInput.value.trim(),
      workflow_status: wfSelect.value,
    };
  }

  function attachRowListeners(tbody) {
    tbody.addEventListener('change', (e) => {
      const row        = e.target.closest('tr');
      const moduleName = row?.dataset.module;
      if (!moduleName) return;
      if (e.target.type === 'checkbox' || e.target.tagName === 'SELECT') {
        upsert(moduleName, getRowFields(row));
      }
    });

    tbody.addEventListener('blur', (e) => {
      if (e.target.type !== 'text') return;
      const row        = e.target.closest('tr');
      const moduleName = row?.dataset.module;
      if (!moduleName) return;
      upsert(moduleName, getRowFields(row));
    }, true);
  }

  // -----------------------------------------------------------------------
  // Upsert — POST to API, update local state + DOM
  // -----------------------------------------------------------------------
  async function upsert(module_name, fields) {
    const mod     = modules.find(m => m.module_name === module_name);
    const current = checklist[module_name] || { checked: 0, tester_name: '', workflow_status: 'Not Tested' };
    const payload = { ...mod, ...current, ...fields };
    const row     = document.querySelector(`tr[data-module="${module_name}"]`);
    const wfSelect = row?.querySelector('select');

    if (wfSelect) {
      wfSelect.disabled = true;
      wfSelect.style.opacity = '0.5';
    }

    try {
      const res = await fetch(`${API_BASE}/api/${APP_SLUG}/checklist`, {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify(payload),
      });
      if (!res.ok) throw new Error(`HTTP ${res.status}`);

      const updated = await res.json();
      checklist[module_name] = updated;

      if (row) row.style.background = updated.checked == 1 ? '#f0fff0' : '';
    } catch (err) {
      console.error('Save failed:', err);
    } finally {
      if (wfSelect) {
        wfSelect.disabled = false;
        wfSelect.style.opacity = '';
      }
    }
  }

  init();
</script>
