# Anthropic API key — required for the chat endpoint.
# Get from https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-key-here

# Express API base URL — used by the React dev server to reach Express.
# Leave blank in .env.production — reverse proxy routes /api/ same-origin in production.
VITE_API_BASE_URL=http://localhost:4001

# Express server settings
PORT=4001
HOST=127.0.0.1

# SQLite file path.
# Dev default: ./server/db/app.sqlite (relative to app root).
# Prod: use an absolute path outside the web root.
DB_PATH=./server/db/app.sqlite

# CORS origin — the Vite dev server URL.
CORS_ORIGIN=http://localhost:5174

# APP SLUG — namespaces API routes so multiple apps can coexist on the same Drupal install.
APP_SLUG=3pd-ai-director
VITE_APP_SLUG=3pd-ai-director

# Drupal base URL — used to build links to Drupal pages in dev.
# Leave blank in .env.production — links are same-origin in production.
VITE_DRUPAL_BASE_URL=https://dev-3-pd-ide.pantheonsite.io
