<?php

/**
 * Implements hook_theme().
 */
function hudx_stracat_theme($existing, $type, $theme, $path) {
  return [
    'hudx_stracat_block' => [
      'variables' => [],
      'template' => 'hudx-react---stracat-block',
      'path' => \Drupal::service('extension.list.module')->getPath('hudx_stracat') . '/templates',
    ],
  ];
}
