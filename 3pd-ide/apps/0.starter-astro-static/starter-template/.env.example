# Base URL of your Drupal site — used only during local development.
# Ask your Drupal site owner for the correct URL.
# Leave blank (or omit this file entirely) when the app is deployed as a Drupal module.
# The module fetches same-origin so no base URL is needed in production.
#
# Example (Lando local):  http://your-site.lndo.site
# Example (other local):  http://localhost:8080
PUBLIC_DRUPAL_BASE_URL=http://your-drupal-site.lndo.site
