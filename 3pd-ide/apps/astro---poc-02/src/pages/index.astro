---
import Layout from '../layouts/Layout.astro';
---

<Layout title="HUDX Astro App">
  <main style="padding: 2rem; max-width: 640px;">
    <h1>Welcome to your HUDX Astro App</h1>
    <p>Pages from Drupal:</p>
    <ul id="nodes-list">
      <li style="color: #999;">Loading…</li>
    </ul>
  </main>
</Layout>

<script>
  // Client-side fetch from Drupal JSON:API.
  // When embedded in Drupal: same-origin, no CORS needed, DRUPAL_BASE = ''.
  // Standalone dev server: set PUBLIC_DRUPAL_BASE_URL in .env to point at your Drupal site.
  const DRUPAL_BASE = import.meta.env.PUBLIC_DRUPAL_BASE_URL || '';

  async function loadNodes() {
    const list = document.getElementById('nodes-list');
    try {
      const res = await fetch(
        `${DRUPAL_BASE}/jsonapi/node/basic_page_layout_builder`
      );
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const { data } = await res.json();

      list.innerHTML = data.length
        ? data.map((n) => `<li>${n.attributes.title}</li>`).join('')
        : '<li style="color:#999">No pages found.</li>';
    } catch (err) {
      list.innerHTML = `<li style="color:#c00">Could not load: ${err.message}</li>`;
    }
  }

  loadNodes();
</script>
