---
export interface Props {
  title: string;
}

const { title } = Astro.props;

const isDev = import.meta.env.DEV;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;0,700;1,400;1,600;1,700&family=Libre+Franklin:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    {isDev && <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.min.css" />}
    {isDev && <link rel="stylesheet" href="/drupal-dev-styles.css" />}
  </head>
  <body>
    {isDev && (
      <nav class="navbar navbar-expand navbar-light bg-warning-subtle border-bottom px-3 py-2" aria-label="Developer navigation">
        <span class="badge bg-warning text-dark me-3 small">DEV</span>
        <div class="navbar-nav gap-3 small">
          <a class="nav-link py-0" href="/">Home</a>
          <a class="nav-link py-0" href="/styleguide">Style Guide</a>
          <a class="nav-link py-0" href="/api-reference">API Reference</a>
        </div>
      </nav>
    )}
    <slot />
    {isDev && <script is:inline src="/drupal-dev-scripts.js"></script>}
    {isDev && <script is:inline>document.body.setAttribute('data-drupal-auth','1');</script>}
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
  }

  :root {
    --ar-navy:    #034f7d;
    --ar-blue:    #1499e8;
    --ar-purple:  #7a4f99;
    --ar-sage:    #85b3b3;
    --ar-yellow:  #f4c32f;
    --ar-rose:    #c96aa6;
    --ar-charcoal:#403d3d;
    --ar-steel:   #7a7878;
    --ar-cement:  #b2b2b2;
    --ar-stone:   #ededed;
  }

  body {
    font-family: 'Libre Franklin', system-ui, sans-serif !important;
    font-size: 1rem !important;
    font-weight: 400 !important;
    line-height: 1.5 !important;
    color: var(--ar-charcoal) !important;
    background: #fff;
    margin: 0;
    padding: 0;
  }

  .font-display {
    font-family: 'Cormorant Garamond', Georgia, serif;
  }
</style>
