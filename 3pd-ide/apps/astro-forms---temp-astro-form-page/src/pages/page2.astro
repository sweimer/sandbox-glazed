---
import Layout from '../layouts/Layout.astro';
---

<Layout title="AlexRenew — RE/NEW for Alexandria">

  <!-- ================================================================
       NAVIGATION
  ================================================================ -->
  <header>
    <nav class="ar-nav" aria-label="Main navigation">
      <div class="ar-nav__inner">
        <a href="/" class="ar-nav__brand" aria-label="AlexRenew home">
          <svg class="ar-nav__logo" viewBox="0 0 32 32" aria-hidden="true" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M16 3C16 3 6 12 6 19a10 10 0 0020 0C26 12 16 3 16 3z" fill="#1499e8"/>
            <path d="M16 11C16 11 10 17 10 21a6 6 0 0012 0C22 17 16 11 16 11z" fill="white" opacity="0.3"/>
          </svg>
          <span class="ar-nav__brand-name">AlexRenew</span>
        </a>
        <div class="ar-nav__menu-group">
          <button class="ar-nav__search" aria-label="Search">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
            <span>Search</span>
          </button>
          <span class="ar-nav__divider" aria-hidden="true">/</span>
          <button class="ar-nav__hamburger" aria-label="Open menu">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
            <span>Menu</span>
          </button>
        </div>
        <a href="/astro-forms---temp-astro-form-page" class="ar-nav__option-link">Option 01</a>
      </div>
    </nav>
  </header>

  <main>

    <!-- ================================================================
         HERO — Kinetic typography
    ================================================================ -->
    <section class="ar-hero" aria-labelledby="hero-heading">
      <div class="ar-hero__bg" aria-hidden="true"></div>

      <div class="ar-hero__kinetic" aria-hidden="true">
        <span class="ar-hero__re">RE</span>
        <em class="ar-hero__tagline font-display">for Alexandria</em>
        <span class="ar-hero__new">NEW</span>
      </div>

      <h1 id="hero-heading" class="visually-hidden">RE/NEW for Alexandria — AlexRenew</h1>

      <div class="ar-hero__bottom">
        <div class="ar-hero__left">
          <p class="ar-hero__statement">Every time you use water,<br />it goes somewhere.</p>
        </div>
        <div class="ar-hero__right">
          <p class="ar-hero__sub">
            The water that leaves homes and businesses is treated, cleaned, and returned safely
            to the river. It's one of the most important systems most people never have to think
            about — because it's being managed every day.
          </p>
          <div class="ar-hero__actions">
            <a href="#news" class="ar-btn ar-btn--primary">What's New</a>
            <a href="#" class="ar-btn ar-btn--outline-white">Pay My Bill</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ================================================================
         SYSTEM AT WORK
    ================================================================ -->
    <section class="ar-system" aria-labelledby="system-heading">
      <div class="ar-system__inner">

        <div class="ar-system__left">
          <p class="ar-eyebrow">The System at Work</p>
          <h2 id="system-heading" class="ar-system__heading">
            <span class="ar-system__heading-sans">Handled with care:</span>
            <em class="ar-system__heading-serif font-display">A shared system</em>
          </h2>
          <p class="ar-system__body">
            Since 1956, we've treated the water that flows through Alexandria every day. What moves
            through homes and businesses becomes part of a shared system — and keeping it working
            takes scale, precision, and constant oversight.
          </p>
          <p class="ar-system__body">Each year, that means:</p>
          <div class="ar-system__stats">
            <div class="ar-sys-stat">
              <span class="ar-sys-stat__num font-display">13B+</span>
              <span class="ar-sys-stat__label">gallons treated</span>
            </div>
            <div class="ar-sys-stat">
              <span class="ar-sys-stat__num font-display">300K+</span>
              <span class="ar-sys-stat__label">people served</span>
            </div>
            <div class="ar-sys-stat">
              <span class="ar-sys-stat__num font-display">2,400t</span>
              <span class="ar-sys-stat__label">nitrogen removed</span>
            </div>
            <div class="ar-sys-stat">
              <span class="ar-sys-stat__num font-display">300t</span>
              <span class="ar-sys-stat__label">phosphorus removed</span>
            </div>
            <div class="ar-sys-stat">
              <span class="ar-sys-stat__num font-display">≈0</span>
              <span class="ar-sys-stat__label">bacteria remaining</span>
            </div>
          </div>
        </div>

        <div class="ar-system__right">
          <div class="ar-accordion">

            <details class="ar-accordion__item" open>
              <summary class="ar-accordion__summary">
                <span>Looking ahead</span>
                <span class="ar-accordion__arrow">→</span>
              </summary>
              <p class="ar-accordion__body">
                An adaptable system that stays reliable, accessible, and ready for what comes next.
                Long-term planning keeps the infrastructure ahead of growth and climate demands.
              </p>
            </details>

            <details class="ar-accordion__item">
              <summary class="ar-accordion__summary">
                <span>Every day impact</span>
                <span class="ar-accordion__arrow">→</span>
              </summary>
              <p class="ar-accordion__body">
                Clean water returns to area neighborhoods — protecting health and the environment
                for the whole community, every single day without interruption.
              </p>
            </details>

            <details class="ar-accordion__item">
              <summary class="ar-accordion__summary">
                <span>What guides us</span>
                <span class="ar-accordion__arrow">→</span>
              </summary>
              <p class="ar-accordion__body">
                This work is tested, verified, and designed to last time, going beyond compliance
                to reduce impact over time. Science and accountability drive every decision.
              </p>
            </details>

          </div>
        </div>

      </div>
    </section>

    <!-- ================================================================
         COMMUNITY SPLIT — Helping protect what matters (light bg)
    ================================================================ -->
    <section class="ar-split" aria-labelledby="community-heading">
      <div class="ar-split__text ar-split__text--light">
        <p class="ar-eyebrow">Investing in the Community</p>
        <h2 id="community-heading" class="ar-split__heading ar-split__heading--dark">
          Helping protect<br /><em class="font-display">what matters</em>
        </h2>
        <p class="ar-split__body ar-split__body--dark">
          This work goes beyond treating wastewater. It shows up in the places people gather,
          the river that runs through our city, and the everyday health of the community.
        </p>
        <p class="ar-split__body ar-split__body--dark">
          These investments show up in shared spaces, local partnerships, and environmental
          improvements. They help keep Alexandria a place people can count on and be proud of.
        </p>
        <div class="ar-split__btns">
          <a href="#" class="ar-split-btn ar-split-btn--dark">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
            Community Benefits
          </a>
          <a href="#" class="ar-split-btn ar-split-btn--dark">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Water Management
          </a>
        </div>
      </div>
      <div class="ar-split__photo ar-split__photo--golden" aria-label="AlexRenew facility at golden hour"></div>
    </section>

    <!-- ================================================================
         COMMUNITY WINS — What this work makes possible (light bg)
    ================================================================ -->
    <section class="ar-split ar-split--reversed" aria-labelledby="wins-heading">
      <div class="ar-split__photo ar-split__photo--urban" aria-label="AlexRenew facility infrastructure"></div>
      <div class="ar-split__text ar-split__text--light">
        <p class="ar-eyebrow">Community Wins</p>
        <h2 id="wins-heading" class="ar-split__heading ar-split__heading--dark ar-split__heading--lg">
          What this work makes possible,<br /><em class="font-display">every day</em>
        </h2>
        <p class="ar-split__body ar-split__body--dark">
          Sustainability is built in. Water is reused. Energy is generated. Less is wasted.
          More than 1 billion gallons of water are reused each year, cutting the need for
          drinking water to be used in operations by nearly 97%.
        </p>
        <div class="ar-wins-card">
          <div class="ar-wins-card__thumb ar-wins-card__thumb--solar" aria-hidden="true"></div>
          <div class="ar-wins-card__body">
            <p class="ar-wins-card__title ar-wins-card__title--dark">Methane from the treatment process</p>
            <p class="ar-wins-card__sub">
              Helps power the facility, covering about 50% of our natural gas needs.
            </p>
          </div>
          <span class="ar-wins-card__arrow" aria-hidden="true">→</span>
        </div>
      </div>
    </section>

    <!-- ================================================================
         STATS BAND — full-width purple
    ================================================================ -->
    <section class="ar-stats-band" aria-labelledby="stats-heading">
      <div class="ar-stats-band__inner">
        <div class="ar-stats-band__intro">
          <p class="ar-eyebrow ar-eyebrow--light">What It Takes</p>
          <h2 id="stats-heading" class="ar-stats-band__heading">
            Behind it all,
            <em class="font-display">the numbers tell the<br />real story</em>
          </h2>
          <p class="ar-stats-band__sub">
            Each number reflects the work being done and outcomes that truly matter —
            protecting public health, caring for the river, and keeping this system
            strong for the long run.
          </p>
        </div>
        <div class="ar-stats-band__grid">
          <div class="ar-stat-item">
            <span class="ar-stat-item__num font-display">40M</span>
            <span class="ar-stat-item__label">gallons treated</span>
          </div>
          <div class="ar-stat-item">
            <span class="ar-stat-item__num font-display">390K</span>
            <span class="ar-stat-item__label">residents served</span>
          </div>
          <div class="ar-stat-item">
            <span class="ar-stat-item__num font-display">100%</span>
            <span class="ar-stat-item__label">renewable energy goal</span>
          </div>
          <div class="ar-stat-item">
            <span class="ar-stat-item__num font-display">70</span>
            <span class="ar-stat-item__label">years serving Alexandria</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ================================================================
         IN ACTION — News carousel
    ================================================================ -->
    <section class="ar-news" id="news" aria-labelledby="news-heading">
      <div class="ar-news__intro">
        <div>
          <p class="ar-eyebrow">In Action</p>
          <h2 id="news-heading" class="ar-news__heading">
            <span class="ar-news__heading-sans">Where the work</span>
            <em class="ar-news__heading-serif font-display">becomes real</em>
          </h2>
          <p class="ar-news__sub">
            The news and stories from across the watershed. Where we track progress, share
            milestones, and show how this work impacts the community of Alexandria, daily.
          </p>
          <a href="#" class="ar-viewall">View All</a>
        </div>
      </div>

      <div class="ar-carousel" role="region" aria-label="News stories">
        <div class="ar-carousel__track" id="carousel-track">

          <article class="ar-carousel__card">
            <div class="ar-carousel__img ar-carousel__img--facility" aria-hidden="true">
              <div class="ar-carousel__overlay">
                <span class="ar-carousel__date">Feb 18, 2025</span>
                <h3 class="ar-carousel__title font-display">AlexRenew Achieves Record Low Nutrient Discharge</h3>
              </div>
            </div>
            <button class="ar-carousel__plus" aria-label="Read more">+</button>
          </article>

          <article class="ar-carousel__card">
            <div class="ar-carousel__img ar-carousel__img--solar" aria-hidden="true">
              <div class="ar-carousel__overlay">
                <span class="ar-carousel__date">Jan 30, 2025</span>
                <h3 class="ar-carousel__title font-display">100% Renewable Energy Goal Reached Three Years Early</h3>
              </div>
            </div>
            <button class="ar-carousel__plus" aria-label="Read more">+</button>
          </article>

          <article class="ar-carousel__card">
            <div class="ar-carousel__img ar-carousel__img--community" aria-hidden="true">
              <div class="ar-carousel__overlay">
                <span class="ar-carousel__date">Jan 12, 2025</span>
                <h3 class="ar-carousel__title font-display">New Workforce Training Program Expands to Spring Cohort</h3>
              </div>
            </div>
            <button class="ar-carousel__plus" aria-label="Read more">+</button>
          </article>

          <article class="ar-carousel__card">
            <div class="ar-carousel__img ar-carousel__img--river" aria-hidden="true">
              <div class="ar-carousel__overlay">
                <span class="ar-carousel__date">Dec 5, 2024</span>
                <h3 class="ar-carousel__title font-display">Potomac River Water Quality Reaches Decade Best</h3>
              </div>
            </div>
            <button class="ar-carousel__plus" aria-label="Read more">+</button>
          </article>

        </div>

        <div class="ar-carousel__dots" role="tablist" aria-label="Carousel navigation">
          <button class="ar-carousel__dot ar-carousel__dot--active" data-slide="0" aria-label="Slide 1"></button>
          <button class="ar-carousel__dot" data-slide="1" aria-label="Slide 2"></button>
        </div>
      </div>
    </section>

    <!-- ================================================================
         CONTACT CTA — no form, just buttons
    ================================================================ -->
    <section class="ar-contact-cta" aria-labelledby="contact-heading">
      <div class="ar-contact-cta__inner">
        <p class="ar-eyebrow">Get in Touch</p>
        <h2 id="contact-heading" class="ar-contact-cta__heading">
          Have a question?
          <em class="font-display" style="color: var(--ar-blue)"> Let us help.</em>
        </h2>
        <p class="ar-contact-cta__sub">
          Whether you're looking for quick answers or need to talk to someone, you'll find it here.
        </p>
        <div class="ar-contact-cta__actions">
          <a href="#" class="ar-btn ar-btn--primary">View All FAQs</a>
          <a href="#" class="ar-btn ar-btn--outline-navy">Contact Us</a>
        </div>
      </div>
    </section>

  </main>

  <!-- ================================================================
       FOOTER
  ================================================================ -->
  <footer class="ar-footer">
    <div class="ar-footer__inner">
      <div class="ar-footer__brand">
        <div class="ar-footer__logo-wrap">
          <svg class="ar-nav__logo" viewBox="0 0 32 32" aria-hidden="true" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M16 3C16 3 6 12 6 19a10 10 0 0020 0C26 12 16 3 16 3z" fill="#1499e8"/>
            <path d="M16 11C16 11 10 17 10 21a6 6 0 0012 0C22 17 16 11 16 11z" fill="white" opacity="0.3"/>
          </svg>
          <span class="ar-nav__brand-name">AlexRenew</span>
        </div>
        <p class="ar-footer__tagline">
          Protecting public health and the environment for Alexandria and
          Northern Virginia since 1956.
        </p>
        <div class="ar-footer__social" aria-label="Social media links">
          <a href="#" aria-label="Facebook"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg></a>
          <a href="#" aria-label="Twitter"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z"/></svg></a>
          <a href="#" aria-label="LinkedIn"><svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg></a>
          <a href="#" aria-label="Instagram"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r=".5" fill="currentColor"/></svg></a>
        </div>
      </div>
      <div class="ar-footer__col">
        <p class="ar-footer__col-heading">Customer Center</p>
        <ul>
          <li><a href="#">Calculate Your Residential Use</a></li>
          <li><a href="#">Frequently Asked Questions</a></li>
          <li><a href="#">LEAP Utility Assistance</a></li>
          <li><a href="#">Watching Reconnection Service</a></li>
          <li><a href="#">Understanding Your Bill</a></li>
          <li><a href="#">Using MyAlexRenew</a></li>
        </ul>
      </div>
      <div class="ar-footer__col">
        <p class="ar-footer__col-heading">About</p>
        <ul>
          <li><a href="#">About AlexRenew</a></li>
          <li><a href="#">Leadership</a></li>
          <li><a href="#">Strategic Plan</a></li>
          <li><a href="#">News &amp; Events</a></li>
          <li><a href="#">Careers</a></li>
        </ul>
      </div>
      <div class="ar-footer__col">
        <p class="ar-footer__col-heading">Contact</p>
        <address>
          <p>1800 Limerick Street<br />Alexandria, VA 22314</p>
          <p>(703) 549-3381</p>
          <p><a href="mailto:info@alexrenew.com">info@alexrenew.com</a></p>
          <p class="ar-footer__emergency">24-hr Emergency Line →</p>
        </address>
      </div>
    </div>
    <div class="ar-footer__bottom">
      <p>&copy; 2025 AlexRenew. All rights reserved.</p>
      <nav aria-label="Footer legal">
        <a href="#">Privacy Policy</a>
        <a href="#">Accessibility</a>
        <a href="#">Public Notices</a>
      </nav>
    </div>
  </footer>

</Layout>

<!-- ================================================================
     STYLES
================================================================ -->
<style>

  .visually-hidden {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0,0,0,0);
    white-space: nowrap; border: 0;
  }

  /* ── NAV ─────────────────────────────────────────────── */
  .ar-nav {
    background: var(--ar-navy);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .ar-nav__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    height: 56px;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .ar-nav__brand {
    display: flex;
    align-items: center;
    gap: .5rem;
    text-decoration: none;
    flex: 1;
  }
  .ar-nav__logo { width: 26px; height: 26px; flex-shrink: 0; }
  .ar-nav__brand-name {
    color: #fff;
    font-family: 'Libre Franklin', sans-serif;
    font-weight: 700;
    font-size: .9375rem;
    letter-spacing: .02em;
  }
  .ar-nav__menu-group {
    display: flex;
    align-items: center;
    gap: .5rem;
    color: rgba(255,255,255,.65);
    font-size: .75rem;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
  }
  .ar-nav__search, .ar-nav__hamburger {
    background: none;
    border: none;
    color: rgba(255,255,255,.65);
    display: flex;
    align-items: center;
    gap: .375rem;
    font-size: .75rem;
    font-weight: 600;
    letter-spacing: .08em;
    text-transform: uppercase;
    cursor: pointer;
    padding: 0;
    transition: color .15s;
    font-family: 'Libre Franklin', sans-serif;
  }
  .ar-nav__search:hover, .ar-nav__hamburger:hover { color: #fff; }
  .ar-nav__divider { color: rgba(255,255,255,.3); }
  .ar-nav__option-link {
    display: inline-block;
    background: var(--ar-blue);
    color: #fff;
    text-decoration: none;
    font-size: .75rem;
    font-weight: 700;
    letter-spacing: .06em;
    text-transform: uppercase;
    padding: .375rem .875rem;
    border-radius: 2px;
    white-space: nowrap;
    transition: background .15s;
    flex-shrink: 0;
  }
  .ar-nav__option-link:hover { background: #0d85d0; }

  /* ── EYEBROW ─────────────────────────────────────────── */
  .ar-eyebrow {
    font-size: .625rem;
    font-weight: 700;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--ar-blue);
    margin: 0 0 .875rem;
  }
  .ar-eyebrow--light { color: var(--ar-sage); }

  /* ── BUTTONS ─────────────────────────────────────────── */
  .ar-btn {
    display: inline-block;
    text-decoration: none;
    font-family: 'Libre Franklin', sans-serif;
    font-size: .8125rem;
    font-weight: 600;
    letter-spacing: .06em;
    text-transform: uppercase;
    padding: .6875rem 1.5rem;
    border-radius: 3px;
    cursor: pointer;
    border: 1.5px solid transparent;
    transition: background .15s, color .15s, border-color .15s;
    line-height: 1;
  }
  .ar-btn--primary { background: var(--ar-blue); color: #fff; border-color: var(--ar-blue); }
  .ar-btn--primary:hover { background: #0d85d0; border-color: #0d85d0; }
  .ar-btn--outline-white { background: transparent; color: #fff; border-color: rgba(255,255,255,.4); }
  .ar-btn--outline-white:hover { border-color: #fff; }
  .ar-btn--outline-navy { background: transparent; color: var(--ar-navy); border-color: var(--ar-navy); }
  .ar-btn--outline-navy:hover { background: var(--ar-navy); color: #fff; }

  /* ── HERO ────────────────────────────────────────────── */
  .ar-hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
  }
  .ar-hero__bg {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to bottom, rgba(2,15,28,.2) 0%, rgba(2,15,28,.5) 50%, rgba(2,15,28,.92) 100%),
      linear-gradient(160deg, #061a28 0%, #0c3050 35%, #0e3d60 60%, #0a2a40 100%);
  }
  .ar-hero__kinetic {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 30%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: .75rem;
    pointer-events: none;
    padding: 0 2rem;
  }
  .ar-hero__re,
  .ar-hero__new {
    font-family: 'Libre Franklin', sans-serif;
    font-size: clamp(5rem, 18vw, 16rem);
    font-weight: 900;
    color: rgba(255,255,255,.88);
    line-height: 1;
    letter-spacing: -.04em;
    text-transform: uppercase;
  }
  .ar-hero__tagline {
    font-size: clamp(1.25rem, 3.5vw, 3rem);
    font-style: italic;
    font-weight: 400;
    color: rgba(255,255,255,.7);
    white-space: nowrap;
    align-self: center;
    letter-spacing: .01em;
  }
  .ar-hero__bottom {
    position: relative;
    z-index: 1;
    display: grid;
