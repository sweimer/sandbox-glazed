  }

</style>

<!-- ================================================================
     DROPDOWN — global so JS-created elements inherit these styles
================================================================ -->
<style is:global>
  /* ── Footer col — JS-injected block content needs global rules ── */
  .ar-footer__col address p {
    font-size: .875rem;
    color: rgba(255,255,255,.55);
    line-height: 1.6;
    margin: 0;
  }
  .ar-footer__col a {
    font-size: .875rem;
    color: rgba(255,255,255,.55);
    text-decoration: none;
    transition: color .15s;
    line-height: 1.5;
  }
  .ar-footer__col a:hover { color: rgba(255,255,255,.9); }
  .ar-footer__emergency {
    font-size: .8125rem !important;
    color: #1499e8 !important;
    font-weight: 600;
  }

  /* ── Reusable edit button — only visible to authenticated Drupal users ── */
  .ar-edit-btn {
    display: none;
    background: none;
    border: none;
    color: rgba(255,255,255,.45);
    cursor: pointer;
    padding: .25rem .375rem;
    border-radius: 3px;
    font-size: 1rem;
    line-height: 1;
    transition: color .15s, background .15s;
    flex-shrink: 0;
  }
  body[data-drupal-auth] .ar-edit-btn { display: inline-flex; align-items: center; }
  .ar-edit-btn:hover { color: #fff; background: rgba(255,255,255,.12); }

  /* Inline variant (nav) */
  #nav-edit-btn { margin-left: .125rem; }

  /* Block-level variant — floats in corner of .ar-editable container */
  .ar-editable { position: relative; }
  .ar-editable > .ar-edit-btn {
    position: absolute;
    top: .5rem;
    right: .5rem;
    z-index: 10;
    font-size: .875rem;
    padding: .2rem .35rem;
    color: rgba(255,255,255,.3);
  }
  .ar-editable > .ar-edit-btn:hover { color: rgba(255,255,255,.9); background: rgba(255,255,255,.1); }

  /* ── Menu editor modal ─────────────────────────────── */
  .ar-menu-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    align-items: center;
    justify-content: center;
  }
  .ar-menu-modal.is-open { display: flex; }
  .ar-menu-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,.65);
    backdrop-filter: blur(3px);
  }
  .ar-menu-modal__panel {
    position: relative;
    z-index: 1;
    width: 90vw;
    max-width: 1100px;
    height: 82vh;
    background: #fff;
    border-radius: 4px;
    box-shadow: 0 24px 64px rgba(0,0,0,.45);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }
  .ar-menu-modal__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: .75rem 1.25rem;
    background: #034f7d;
    flex-shrink: 0;
  }
  .ar-menu-modal__title {
    color: #fff;
    font-size: .875rem;
    font-weight: 600;
    letter-spacing: .02em;
    display: flex;
    align-items: center;
    gap: .5rem;
  }
  .ar-menu-modal__close {
    background: none;
    border: none;
    color: rgba(255,255,255,.65);
    cursor: pointer;
    font-size: 1.125rem;
    line-height: 1;
    padding: .25rem;
    display: flex;
    align-items: center;
    transition: color .15s;
  }
  .ar-menu-modal__close:hover { color: #fff; }
  .ar-menu-modal__frame {
    flex: 1;
    border: none;
    width: 100%;
  }

  /* ── Nav link base — scoped rule can't reach JS-created elements ── */
  .ar-nav__links a {
    color: rgba(255,255,255,.8);
    text-decoration: none;
    font-size: .8125rem;
    font-weight: 500;
    letter-spacing: .02em;
    transition: color .15s;
  }
  .ar-nav__links a:hover { color: #fff; }
  .ar-nav__links .ar-nav__option-link {
    color: var(--ar-yellow) !important;
    border-bottom: 1px solid rgba(244,195,47,.4);
    padding-bottom: 1px;
    text-decoration: none;
  }
  .ar-nav__links .ar-nav__option-link:hover { color: #fff !important; border-color: transparent; }

  .ar-nav__links li { position: relative; }
  .ar-nav__chevron {
    display: inline-block;
    font-style: normal;
    font-size: .625rem;
    margin-left: .25rem;
    opacity: .6;
    transition: transform .2s;
    vertical-align: middle;
  }
  .ar-nav__links li:hover .ar-nav__chevron,
  .ar-nav__links li:focus-within .ar-nav__chevron { transform: rotate(180deg); opacity: 1; }
  .ar-nav__dropdown {
    visibility: hidden;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    top: 24px;
    left: 0;
    padding-top: .5rem;
    padding-left: 0;
    min-width: 200px;
    list-style: none;
    margin: 0;
    z-index: 200;
    /* hide delay: gives the cursor time to travel into the dropdown */
    transition: opacity .15s ease, visibility .15s ease;
    transition-delay: .2s;
  }
  .ar-nav__dropdown > li {
    background: #0d1f30;
  }
  .ar-nav__dropdown > li:first-child { border-radius: 3px 3px 0 0; }
  .ar-nav__dropdown > li:last-child  { border-radius: 0 0 3px 3px; }
  .ar-nav__dropdown > li:first-child { border-top: 1px solid rgba(255,255,255,.12); }
  .ar-nav__dropdown > li            { border-left: 1px solid rgba(255,255,255,.12); border-right: 1px solid rgba(255,255,255,.12); }
  .ar-nav__dropdown > li:last-child { border-bottom: 1px solid rgba(255,255,255,.12); box-shadow: 0 8px 28px rgba(0,0,0,.45); }
  .ar-nav__links li:hover .ar-nav__dropdown,
  .ar-nav__links li:focus-within .ar-nav__dropdown {
    visibility: visible;
    opacity: 1;
    pointer-events: auto;
    transition-delay: 0s; /* show immediately */
  }
  .ar-nav__dropdown li a {
    display: block;
    padding: .5rem 1.125rem;
    white-space: nowrap;
    color: rgba(255,255,255,.72) !important;
    font-size: .8125rem;
    font-weight: 400;
    letter-spacing: .01em;
    transition: color .15s, background .15s;
  }
  .ar-nav__dropdown li a:hover { color: #fff !important; background: rgba(255,255,255,.07); }
</style>

<!-- ================================================================
     SCRIPTS
================================================================ -->
<script>
  const API_BASE = import.meta.env.PUBLIC_API_BASE_URL || '';
  const APP_SLUG = import.meta.env.PUBLIC_APP_SLUG     || '';
  const ENDPOINT = `${API_BASE}/api/${APP_SLUG}/submissions`;

  // ── Drupal edit modal — reusable across the whole page ───
  const modal         = document.getElementById('menu-modal');
  const modalClose    = document.getElementById('menu-modal-close');
  const modalBackdrop = document.getElementById('menu-modal-backdrop');
  const modalFrame    = document.getElementById('menu-modal-frame');

  const modalTitleText = document.getElementById('menu-modal-title-text');

  function openModal(adminUrl, title = 'Edit Block') {
    modalTitleText.textContent = title;
    modalFrame.src = adminUrl;
    modal.classList.add('is-open');
    modal.setAttribute('aria-hidden', 'false');
  }
  function closeModal() {
    modal.classList.remove('is-open');
    modal.setAttribute('aria-hidden', 'true');
    modalFrame.src = '';
  }

  // Factory: creates an .ar-edit-btn wired to any Drupal admin URL
  function makeEditBtn(adminUrl, title = 'Edit Block') {
    const btn = document.createElement('button');
    btn.className = 'ar-edit-btn';
    btn.setAttribute('aria-label', 'Edit in Drupal');
    btn.innerHTML = '<i class="bi bi-pencil-square"></i>';
    btn.addEventListener('click', () => openModal(adminUrl, title));
    return btn;
  }

  document.getElementById('nav-edit-btn')?.addEventListener('click', () => openModal('/admin/structure/menu/manage/main', 'Edit Navigation Menu'));
  modalClose?.addEventListener('click', closeModal);
  modalBackdrop?.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal?.classList.contains('is-open')) closeModal();
  });

  // ── Footer contact block from Drupal JSON:API ─────────
  const DRUPAL_BASE = import.meta.env.PUBLIC_DRUPAL_BASE_URL || '';
  (async () => {
    try {
      const res = await fetch(
        `${DRUPAL_BASE}/jsonapi/block_content/basic` +
        `?filter[info]=Home%20Page%20-%20Footer%20-%20Contact` +
        `&fields[block_content--basic]=body,drupal_internal__id`
      );
      if (!res.ok) return;
      const { data } = await res.json();
      const item = data?.[0];
      if (!item) return;
      const bodyHtml = item.attributes.body?.processed || item.attributes.body?.value || '';
      const blockId  = item.attributes.drupal_internal__id;
      if (!bodyHtml) return;
      const col     = document.getElementById('footer-contact');
      const address = col?.querySelector('address');
      if (address) address.innerHTML = bodyHtml;
      if (col && blockId) col.appendChild(makeEditBtn(`/admin/content/block/${blockId}`, 'Edit Block'));
    } catch (_) { /* keep static fallback */ }
  })();

  // ── Footer about block from Drupal JSON:API ───────────
  loadFooterAbout();
  async function loadFooterAbout() {
    try {
      const res = await fetch(
        `${DRUPAL_BASE}/jsonapi/block_content/basic` +
        `?filter[info]=Home%20Page%20-%20Footer%20-%20About` +
        `&fields[block_content--basic]=body,drupal_internal__id`
      );
      if (!res.ok) return;
      const { data } = await res.json();
      const item = data?.[0];
      if (!item) return;
      const bodyHtml = item.attributes.body?.processed || item.attributes.body?.value || '';
      const blockId  = item.attributes.drupal_internal__id;
      if (!bodyHtml) return;
      const col = document.getElementById('footer-about');
      const ul  = col?.querySelector('ul');
      if (ul) ul.outerHTML = bodyHtml;
      if (col && blockId) col.appendChild(makeEditBtn(`/admin/content/block/${blockId}`, 'Edit Block'));
    } catch (_) { /* keep static fallback */ }
  }

  // ── Dynamic nav from Drupal menu API ──────────────────
  (async () => {
    try {
      const res = await fetch(`${API_BASE}/api/${APP_SLUG}/menu/main`);
      if (!res.ok) return;
      const items = await res.json();
      if (!Array.isArray(items) || !items.length) return;
      const nav = document.querySelector('.ar-nav__links');
      if (!nav) return;
      const option2 = nav.querySelector('.ar-nav__option-link')?.closest('li')?.cloneNode(true);
      nav.innerHTML = '';
      items.forEach(({ title, url, children }) => {
        const li = document.createElement('li');
        const a  = document.createElement('a');
        a.href = url || '#';
        if (children && children.length) {
          a.textContent = title;
          const chevron = document.createElement('span');
          chevron.className   = 'ar-nav__chevron';
          chevron.textContent = '▾';
          chevron.setAttribute('aria-hidden', 'true');
          a.appendChild(chevron);
          const dropdown = document.createElement('ul');
          dropdown.className = 'ar-nav__dropdown';
          dropdown.setAttribute('role', 'list');
          children.forEach(child => {
            const childLi = document.createElement('li');
            const childA  = document.createElement('a');
            childA.href        = child.url || '#';
            childA.textContent = child.title;
            childLi.appendChild(childA);
            dropdown.appendChild(childLi);
          });
          li.appendChild(a);
          li.appendChild(dropdown);
        } else {
          a.textContent = title;
          li.appendChild(a);
        }
        nav.appendChild(li);
      });
      if (option2) nav.appendChild(option2);
    } catch (_) { /* keep static fallback */ }
  })();

  // ── Tab switching ─────────────────────────────────────
  document.querySelectorAll('.ar-tab').forEach(tab => {
    tab.addEventListener('click', () => {
      document.querySelectorAll('.ar-tab').forEach(t => {
        t.classList.remove('ar-tab--active');
        t.setAttribute('aria-selected', 'false');
      });
      tab.classList.add('ar-tab--active');
      tab.setAttribute('aria-selected', 'true');
    });
  });

  // ── Load submissions ──────────────────────────────────
  async function loadSubmissions() {
    try {
      const res = await fetch(ENDPOINT);
      if (!res.ok) return;
      const rows = await res.json();
      if (!rows.length) return;
      const section = document.getElementById('submissions-section');
      const tbody   = document.getElementById('submissions-tbody');
      section.style.display = '';
      tbody.innerHTML = rows.map(r => `
        <tr>
          <td>${r.first_name} ${r.last_name}</td>
          <td>${r.email}</td>
          <td>${r.topic}</td>
          <td>${r.message}</td>
          <td style="white-space:nowrap;color:var(--ar-steel)">${r.created_at}</td>
        </tr>`).join('');
    } catch (_) {}
  }

  // ── Form submit ───────────────────────────────────────
  const form      = document.getElementById('contact-form');
  const errEl     = document.getElementById('form-error');
  const succEl    = document.getElementById('form-success');
  const submitBtn = document.getElementById('submit-btn');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errEl.style.display  = 'none';
    succEl.style.display = 'none';
    submitBtn.disabled   = true;
    submitBtn.textContent = 'Sending…';

    const data = {
      first_name: form.first_name.value.trim(),
      last_name:  form.last_name.value.trim(),
      email:      form.email.value.trim(),
      topic:      form.topic.value,
      message:    form.message.value.trim(),
    };

    try {
      const res = await fetch(ENDPOINT, {
        method:  'POST',
        headers: { 'Content-Type': 'application/json' },
        body:    JSON.stringify(data),
      });
      if (!res.ok) {
        const err = await res.json().catch(() => ({}));
        throw new Error(err.error || `HTTP ${res.status}`);
      }
      form.reset();
      succEl.style.display = '';
      await loadSubmissions();
    } catch (err) {
      errEl.textContent    = `Submission failed: ${err.message}`;
      errEl.style.display  = '';
    } finally {
      submitBtn.disabled    = false;
      submitBtn.textContent = 'Send Message';
    }
  });

  loadSubmissions();
</script>
