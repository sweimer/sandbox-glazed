<?php

/**
 * Implements hook_theme().
 */
function hudx_3pd_ai_coder_theme($existing, $type, $theme, $path) {
  return [
    'hudx_3pd_ai_coder_block' => [
      'variables' => [],
      'template' => 'hudx-3pd-ai-coder-block',
      'path' => \Drupal::service('extension.list.module')->getPath('hudx_3pd_ai_coder') . '/templates',
    ],
  ];
}
