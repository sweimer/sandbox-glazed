---
export interface Props {
  title: string;
}

const { title } = Astro.props;

// Drupal theme styles are loaded during local dev only.
// import.meta.env.DEV is false during `astro build`, so these <link> tags
// are never included in the compiled module output.
//
// Two sources of theme styles (mutually exclusive):
//   PUBLIC_ASSETS_URL set → load from client's hudx_3pd_assets Drupal module endpoint
//   Not set             → load from local drupal-dev-styles.css (HUDx/Bootstrap default)
//
// Set PUBLIC_ASSETS_URL in .env when working on a non-HUDx project.
// Generate drupal-dev-styles.css by running: 3pd styles sync
const isDev      = import.meta.env.DEV;
const assetsUrl  = import.meta.env.PUBLIC_ASSETS_URL || '';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {isDev && <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.min.css" />}
    {isDev && assetsUrl && <link rel="stylesheet" href={`${assetsUrl}/styles.css`} />}
    {isDev && !assetsUrl && <link rel="stylesheet" href="/drupal-dev-styles.css" />}
  </head>
  <body>
    {isDev && (
      <nav class="navbar navbar-expand navbar-light bg-warning-subtle border-bottom px-3 py-2" aria-label="Developer navigation">
        <span class="badge bg-warning text-dark me-3 small">DEV</span>
        <div class="navbar-nav gap-3 small">
          <a class="nav-link py-0" href="/">Home</a>
          <a class="nav-link py-0" href="/styleguide">Style Guide</a>
          <a class="nav-link py-0" href="/api-reference">API Reference</a>
        </div>
      </nav>
    )}
    <slot />
    {isDev && assetsUrl && <script is:inline src={`${assetsUrl}/scripts.js`}></script>}
    {isDev && !assetsUrl && <script is:inline src="/drupal-dev-scripts.js"></script>}
    {isDev && <script is:inline>document.body.setAttribute('data-drupal-auth','1');</script>}
  </body>
</html>

<style is:global>
  * {
    box-sizing: border-box;
  }

  body {
    font-family: system-ui, sans-serif;
    margin: 0;
    padding: 0;
  }
</style>
