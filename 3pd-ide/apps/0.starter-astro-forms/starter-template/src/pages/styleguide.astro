---
/**
 * styleguide.astro — DEV ONLY
 *
 * Demonstrates Bootstrap / DXPR theme tokens in the actual Drupal theme CSS.
 * Accessible only via the DEV nav — not included in the Drupal module output.
 * Bootstrap JS (accordion, collapse) is provided by drupal-dev-scripts.js.
 */
import Layout from '../layouts/Layout.astro';
---

<Layout title="Style Guide — DEV">

  <div class="container my-4">

    <header class="mb-5">
      <span class="badge bg-warning text-dark mb-2">DEV REFERENCE</span>
      <h1 class="h3 mb-1">Style Guide</h1>
      <p class="text-muted mb-0">
        The styles on this page are rendered using the <strong>actual Drupal theme CSS</strong> loaded
        into your dev environment — not a mock. What you see here is exactly what your app
        will look like inside Drupal. Build with confidence using the classes below.
      </p>
    </header>

    <!-- TYPOGRAPHY -->
    <section class="mb-5">
      <h2 class="h5 fw-semibold border-bottom pb-2 mb-4 text-primary">Typography</h2>
      <h1>Heading 1 <small class="text-muted fs-6">h1</small></h1>
      <h2>Heading 2 <small class="text-muted fs-6">h2</small></h2>
      <h3>Heading 3 <small class="text-muted fs-6">h3</small></h3>
      <h4>Heading 4 <small class="text-muted fs-6">h4</small></h4>
      <h5>Heading 5 <small class="text-muted fs-6">h5</small></h5>
      <h6>Heading 6 <small class="text-muted fs-6">h6</small></h6>
      <hr />
      <p class="lead">Lead paragraph — use for introductory copy. Class: <code>lead</code></p>
      <p>Body text — default paragraph size. No class needed.</p>
      <p class="small text-muted">Small muted text — captions, hints, metadata. Classes: <code>small text-muted</code></p>
      <p><strong>Bold</strong> · <em>Italic</em> · <u>Underline</u> · <s>Strikethrough</s> · <code>inline code</code></p>
      <blockquote class="blockquote border-start border-primary ps-3">
        <p class="mb-1">"A blockquote for callouts or pull quotes."</p>
        <footer class="blockquote-footer">Source or attribution</footer>
      </blockquote>
    </section>

    <!-- COLOR PALETTE -->
    <section class="mb-5">
      <h2 class="h5 fw-semibold border-bottom pb-2 mb-4 text-primary">Color Palette</h2>
      <div class="row g-2 mb-3">
        {[
          ['primary','Primary'],['secondary','Secondary'],['success','Success'],['danger','Danger'],
          ['warning','Warning'],['info','Info'],['light','Light'],['dark','Dark'],
        ].map(([color, label]) => (
          <div class="col-6 col-md-3 col-lg-2">
            <div class={`bg-${color} rounded p-3 mb-1`} style="min-height:60px"></div>
            <p class="small mb-0 fw-semibold">{label}</p>
            <p class="small text-muted mb-0"><code>bg-{color}</code></p>
          </div>
        ))}
      </div>
      <p class="small text-muted">
        Text variants:
        <span class="text-primary">text-primary</span> ·
        <span class="text-success">text-success</span> ·
        <span class="text-danger">text-danger</span> ·
        <span class="text-warning">text-warning</span> ·
        <span class="text-muted">text-muted</span>
      </p>
    </section>

    <!-- BUTTONS -->
    <section class="mb-5">
      <h2 class="h5 fw-semibold border-bottom pb-2 mb-4 text-primary">Buttons</h2>
      <div class="d-flex flex-wrap gap-2 mb-3">
        <button class="btn btn-primary">Primary</button>
        <button class="btn btn-secondary">Secondary</button>
        <button class="btn btn-success">Success</button>
        <button class="btn btn-danger">Danger</button>
        <button class="btn btn-warning">Warning</button>
        <button class="btn btn-info">Info</button>
        <button class="btn btn-light">Light</button>
        <button class="btn btn-dark">Dark</button>
      </div>
      <div class="d-flex flex-wrap gap-2 mb-3">
        <button class="btn btn-outline-primary">Outline Primary</button>
        <button class="btn btn-outline-secondary">Outline Secondary</button>
        <button class="btn btn-outline-success">Outline Success</button>
        <button class="btn btn-outline-danger">Outline Danger</button>
      </div>
      <div class="d-flex flex-wrap align-items-center gap-2">
        <button class="btn btn-primary btn-lg">Large</button>
        <button class="btn btn-primary">Default</button>
        <button class="btn btn-primary btn-sm">Small</button>
        <button class="btn btn-primary" disabled>Disabled</button>
      </div>
    </section>

    <!-- ALERTS -->
    <section class="mb-5">
      <h2 class="h5 fw-semibold border-bottom pb-2 mb-4 text-primary">Alerts</h2>
      {['primary','success','warning','danger','info','secondary'].map(color => (
        <div class={`alert alert-${color} d-flex align-items-center gap-2`} role="alert">
          <i class="bi bi-info-circle-fill flex-shrink-0" aria-hidden="true"></i>
          <span>
            <strong class="text-capitalize">{color}:</strong> Use <code>alert alert-{color}</code> for this style.
          </span>
        </div>
      ))}
    </section>

    <!-- BADGES -->
    <section class="mb-5">
      <h2 class="h5 fw-semibold border-bottom pb-2 mb-4 text-primary">Badges</h2>
      <div class="d-flex flex-wrap gap-2 mb-3">
        {['primary','secondary','success','danger','warning','info','light','dark'].map(c => (
          <span class={`badge bg-${c} ${c === 'light' ? 'text-dark' : ''}`}>{c}</span>
        ))}
      </div>
      <div class="d-flex flex-wrap gap-2">
        {['primary','success','danger','warning'].map(c => (
          <span class={`badge rounded-pill bg-${c}`}>Pill · {c}</span>
        ))}
      </div>
    </section>

    <!-- CARDS -->
    <section class="mb-5">
      <h2 class="h5 fw-semibold border-bottom pb-2 mb-4 text-primary">Cards</h2>
      <div class="row g-3">
        <div class="col-md-4">
          <div class="card shadow-sm">
            <div class="card-body">
              <h5 class="card-title">Basic Card</h5>
              <p class="card-text text-muted small">Body copy goes here.</p>
              <a href="#" class="btn btn-primary btn-sm">Action</a>
            </div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card border-primary shadow-sm">
            <div class="card-header bg-primary text-white">Colored header</div>
            <div class="card-body">
              <p class="card-text small">Use <code>card-header bg-{'{color}'}</code>.</p>
            </div>
            <div class="card-footer text-muted small">Footer text</div>
          </div>
        </div>
        <div class="col-md-4">
          <div class="card h-100 shadow-sm">
            <div class="card-body d-flex flex-column">
              <h5 class="card-title">Full-height card</h5>
              <p class="card-text text-muted small flex-grow-1">Use <code>h-100</code> + <code>d-flex flex-column</code> to pin the button to the bottom.</p>
              <a href="#" class="btn btn-outline-primary btn-sm mt-auto">Pinned action</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FORM ELEMENTS -->
    <section class="mb-5">
      <h2 class="h5 fw-semibold border-bottom pb-2 mb-4 text-primary">Form Elements</h2>
      <div class="row g-3" style="max-width:560px">
        <div class="col-12">
          <label for="sg-text" class="form-label">Text input</label>
          <input id="sg-text" type="text" class="form-control" placeholder="Placeholder text" />
        </div>
        <div class="col-12">
          <label for="sg-select" class="form-label">Select</label>
          <select id="sg-select" class="form-select">
            <option value="">Choose an option…</option>
            <option value="a">Option A</option>
            <option value="b">Option B</option>
            <option value="c">Option C</option>
          </select>
        </div>
        <div class="col-12">
          <label for="sg-textarea" class="form-label">Textarea</label>
          <textarea id="sg-textarea" class="form-control" rows="3" placeholder="Multi-line input"></textarea>
        </div>
        <div class="col-12">
          <div class="form-check">
            <input id="sg-check" type="checkbox" class="form-check-input" />
            <label for="sg-check" class="form-check-label">Checkbox label</label>
          </div>
        </div>
        <div class="col-12">
          <label for="sg-range" class="form-label">Range input</label>
          <input id="sg-range" type="range" class="form-range" />
        </div>
        <div class="col-12 d-flex gap-2">
          <button class="btn btn-primary">Submit</button>
          <button class="btn btn-outline-secondary" type="reset">Reset</button>
        </div>
      </div>
    </section>

    <!-- TABLE -->
    <section class="mb-5">
      <h2 class="h5 fw-semibold border-bottom pb-2 mb-4 text-primary">Table</h2>
      <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
          <thead class="table-dark">
            <tr>
              <th scope="col">#</th>
              <th scope="col">Name</th>
              <th scope="col">Status</th>
              <th scope="col">Date</th>
              <th scope="col"></th>
            </tr>
          </thead>
          <tbody>
            {[
              { id: 1, name: 'First entry',  status: 'Active',  date: '2026-04-01' },
              { id: 2, name: 'Second entry', status: 'Pending', date: '2026-04-02' },
              { id: 3, name: 'Third entry',  status: 'Closed',  date: '2026-04-03' },
            ].map(row => (
              <tr>
                <td>{row.id}</td>
                <td>{row.name}</td>
                <td>
                  <span class={`badge bg-${row.status === 'Active' ? 'success' : row.status === 'Pending' ? 'warning' : 'secondary'}`}>
                    {row.status}
                  </span>
                </td>
                <td class="text-muted small">{row.date}</td>
                <td><a href="#" class="btn btn-outline-primary btn-sm">View</a></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- ACCORDION — Bootstrap JS handles open/close via data attributes -->
    <section class="mb-5">
      <h2 class="h5 fw-semibold border-bottom pb-2 mb-4 text-primary">Accordion</h2>
      <div class="accordion" id="sg-accordion">
        {[
          { id: 'one',   title: 'Accordion item one',   body: 'Content for the first panel. Click the header to collapse.' },
          { id: 'two',   title: 'Accordion item two',   body: 'Content for the second panel.' },
          { id: 'three', title: 'Accordion item three', body: 'Content for the third panel.' },
        ].map(({ id, title, body }) => (
          <div class="accordion-item">
            <h2 class="accordion-header">
              <button
                class="accordion-button collapsed"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target={`#acc-${id}`}
                aria-expanded="false"
                aria-controls={`acc-${id}`}
              >
                {title}
              </button>
            </h2>
            <div id={`acc-${id}`} class="accordion-collapse collapse" data-bs-parent="#sg-accordion">
              <div class="accordion-body small">{body}</div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- LIST GROUP -->
    <section class="mb-5">
      <h2 class="h5 fw-semibold border-bottom pb-2 mb-4 text-primary">List Group</h2>
      <div class="row g-3">
        <div class="col-md-4">
          <ul class="list-group">
            <li class="list-group-item active" aria-current="true">Active item</li>
            <li class="list-group-item">Default item</li>
            <li class="list-group-item">Another item</li>
            <li class="list-group-item text-muted">Muted item</li>
            <li class="list-group-item disabled" aria-disabled="true">Disabled item</li>
          </ul>
        </div>
        <div class="col-md-4">
          <ul class="list-group">
            {['primary','success','warning','danger','info'].map(c => (
              <li class={`list-group-item list-group-item-${c}`}>list-group-item-{c}</li>
            ))}
          </ul>
        </div>
        <div class="col-md-4">
          <ul class="list-group">
            {['First item','Second item','Third item'].map((item, i) => (
              <li class="list-group-item d-flex justify-content-between align-items-center">
                {item}
                <span class="badge bg-primary rounded-pill">{i + 1}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

  </div>

</Layout>
