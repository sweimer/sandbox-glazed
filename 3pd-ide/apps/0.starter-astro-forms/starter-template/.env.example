# -----------------------------------------------------------------------
# DRUPAL — CMS content source (read-only)
# Ask your Drupal site owner for the correct URL.
# Leave blank when the app is deployed as a Drupal module (same-origin).
# -----------------------------------------------------------------------
PUBLIC_DRUPAL_BASE_URL=http://your-drupal-site.lndo.site

# -----------------------------------------------------------------------
# EXPRESS API — data backend (forms / submissions)
# In dev: full URL to Express server (different port from Astro).
# In production: leave blank — reverse proxy routes /api/ on same domain.
# -----------------------------------------------------------------------
PUBLIC_API_BASE_URL=http://127.0.0.1:3001

# -----------------------------------------------------------------------
# SERVER — Express settings (read by server/server.js at startup)
# -----------------------------------------------------------------------
PORT=3001

# SQLite file location.
# Dev default: ./server/db/app.sqlite (relative to app root).
# Prod: use an absolute path outside the web root, e.g.:
#   DB_PATH=/var/app-data/my-app/app.sqlite
DB_PATH=./server/db/app.sqlite

# CORS origin — the Astro dev server URL. Only needed locally.
CORS_ORIGIN=http://localhost:4321

# -----------------------------------------------------------------------
# APP SLUG — used to namespace API routes so multiple apps can coexist
# on the same Drupal install without route conflicts.
# Set automatically by `3pd astro-forms app <name>` — do not edit manually.
# -----------------------------------------------------------------------
APP_SLUG=YOUR_APP_SLUG
PUBLIC_APP_SLUG=YOUR_APP_SLUG
