# Express API base URL — used by the React dev server to reach Express.
# Leave blank in .env.production — reverse proxy routes /api/ same-origin in production.
VITE_API_BASE_URL=http://127.0.0.1:4000

# Drupal base URL — used to fetch content from Drupal's JSON:API at runtime (Card 2 pattern).
# Example: https://your-site.lndo.site  or  https://your-site.pantheonsite.io
# Leave blank if this app does not fetch content from Drupal.
VITE_DRUPAL_BASE_URL=

# Express server settings
PORT=4000
HOST=127.0.0.1

# Vite dev server port — assigned automatically by `3pd react app` to avoid
# conflicts when multiple apps run simultaneously. Do not edit manually.
DEV_PORT=5173

# SQLite file path.
# Dev default: ./server/db/app.sqlite (relative to app root).
# Prod: use an absolute path outside the web root, e.g.:
#   DB_PATH=/var/app-data/my-app/app.sqlite
DB_PATH=./server/db/app.sqlite

# CORS origin — the Vite dev server URL.
CORS_ORIGIN=http://localhost:5173

# APP SLUG — namespaces API routes so multiple apps can coexist on the same Drupal install.
# Set automatically by `3pd react app <name>` — do not edit manually.
APP_SLUG=YOUR_APP_SLUG
VITE_APP_SLUG=YOUR_APP_SLUG
